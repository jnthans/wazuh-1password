<!-- ==========================================================================
     onepassword_decoder.xml
     Wazuh decoder for the 1Password Events API wodle
     ==========================================================================

     HOW WAZUH DECODES 1PASSWORD EVENTS
     ────────────────────────────────────
     Every event emitted by the wodle is a single JSON line on stdout:

       {
         "integration": "1password",
         "op": {
           "event_type": "<event_type>",
           ... all 1Password fields, native JSON structure ...
         }
       }

     The decoder below matches on the integration field. Wazuh's JSON decoder
     then traverses the entire document and makes every field available to
     rules using dot-notation. In rule <field> tags and $(variable)
     descriptions, fields are referenced WITHOUT the 'data.' prefix:

       Field tag:          <field name="op.action">
       Description var:    $(op.actor_uuid)
       OpenSearch query:   data.op.action   (the 'data.' prefix is added
                           by the Wazuh API layer, not by the rule engine)

     No explicit field extraction lines are needed beyond this single decoder.
     Wazuh's built-in JSON decoder handles all nested field mapping
     automatically once the parent decoder establishes the match.

     INSTALLATION
     ────────────
     Copy to /var/ossec/etc/decoders/onepassword_decoder.xml
     Restart Wazuh manager: systemctl restart wazuh-manager
     ========================================================================== -->

<decoder name="onepassword">
  <prematch>{"integration": "1password"</prematch>
  <plugin_decoder>JSON_Decoder</plugin_decoder>
</decoder>
