<!-- ==========================================================================
     onepassword_rules.xml
     Wazuh rules for the 1Password Events API wodle
     ==========================================================================

     RULE ID ALLOCATION
     ──────────────────
     100700 – 100799  1Password Events API integration rules

     Block layout:
       100700          Parent / base rule  (all 1Password events)
       100701–100709   Integration health  (errors, run summary)
       100710–100729   Audit events  (admin actions)
       100730–100739   Sign-in attempts
       100740–100749   Item usage events
       100750–100759   Composite / correlation rules

     FIELD NAMING IN RULES
     ──────────────────────
     Wazuh's JSON decoder creates fields named exactly as they appear in the
     decoded JSON, without any prefix. The 'data.' prefix is added by the
     Wazuh API and OpenSearch query layer — it is NOT used inside rule XML.

     Correct:   <field name="op.action">
     Wrong:     <field name="data.op.action">

     Correct description variable:   $(op.actor_uuid)
     Wrong description variable:     $(data.op.actor_uuid)

     INSTALLATION
     ────────────
     Copy to /var/ossec/etc/rules/onepassword_rules.xml
     Restart Wazuh manager: systemctl restart wazuh-manager
     ========================================================================== -->

<group name="onepassword,">

  <!-- ════════════════════════════════════════════════════════════════════════
       BASE RULE
       Matches all 1Password events. All rules below use this as their parent.
       ════════════════════════════════════════════════════════════════════════ -->

  <rule id="100700" level="0">
    <decoded_as>json</decoded_as>
    <field name="integration">^1password$</field>
    <description>1Password Events API event</description>
    <options>no_full_log</options>
    <group>onepassword,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════════════════
       INTEGRATION HEALTH — errors and run summary
       ════════════════════════════════════════════════════════════════════════ -->

  <!-- Any error event from any source -->
  <rule id="100701" level="8">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^error$</field>
    <description>1Password integration error: $(op.error_code) [$(op.source)]</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- Credential / auth failures — always high severity -->
  <rule id="100702" level="12">
    <if_sid>100701</if_sid>
    <field name="op.error_code">^API_HTTP_401$|^CONFIG_MISSING_CREDENTIAL$</field>
    <description>1Password credential failure: $(op.error_message)</description>
    <group>onepassword,onepassword_error,authentication_failures,</group>
  </rule>

  <!-- Rate limit reached -->
  <rule id="100703" level="8">
    <if_sid>100701</if_sid>
    <field name="op.error_code">^API_HTTP_429$</field>
    <description>1Password Events API rate limit reached [$(op.source)]</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- Network / connectivity failure -->
  <rule id="100704" level="8">
    <if_sid>100701</if_sid>
    <field name="op.error_code">^API_CONNECTION_ERROR$|^API_TIMEOUT$</field>
    <description>1Password Events API unreachable or timed out [$(op.source)]</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- State read or write failure -->
  <rule id="100705" level="8">
    <if_sid>100701</if_sid>
    <field name="op.error_code">^STATE_READ_ERROR$|^STATE_WRITE_ERROR$</field>
    <description>1Password state file error — potential data gap on next run</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- Audit stream failure in run summary -->
  <rule id="100706" level="10">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^run_summary$</field>
    <field name="op.audit_success">^false$</field>
    <description>1Password audit event stream failed — admin actions may be delayed</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- Signin stream failure in run summary -->
  <rule id="100707" level="10">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^run_summary$</field>
    <field name="op.signin_success">^false$</field>
    <description>1Password sign-in stream failed — authentication events may be delayed</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- Item usage stream failure in run summary -->
  <rule id="100708" level="6">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^run_summary$</field>
    <field name="op.itemusage_success">^false$</field>
    <description>1Password item usage stream failed — vault access events may be delayed</description>
    <group>onepassword,onepassword_error,</group>
  </rule>

  <!-- Repeated auth failures (frequency rule — 2 failures in 10 minutes) -->
  <rule id="100709" level="14" frequency="2" timeframe="600">
    <if_matched_sid>100702</if_matched_sid>
    <description>1Password repeated credential failures — possible misconfiguration or revoked token</description>
    <group>onepassword,onepassword_error,authentication_failures,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════════════════
       AUDIT EVENTS — administrative actions
       ════════════════════════════════════════════════════════════════════════ -->

  <!-- Base audit event -->
  <rule id="100710" level="3">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^audit_event$</field>
    <description>1Password audit event: $(op.action) on $(op.object_type) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,</group>
  </rule>

  <!-- User provisioning / deprovisioning -->
  <rule id="100711" level="5">
    <if_sid>100710</if_sid>
    <field name="op.action">^activate$|^deactivate$|^reactivate$|^delete$|^suspend$</field>
    <description>1Password user lifecycle change: $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,account_change,</group>
  </rule>

  <!-- Group membership change -->
  <rule id="100712" level="5">
    <if_sid>100710</if_sid>
    <field name="op.object_type">^gm$</field>
    <description>1Password group membership changed: $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,group_change,</group>
  </rule>

  <!-- Vault access permissions change -->
  <rule id="100713" level="8">
    <if_sid>100710</if_sid>
    <field name="op.object_type">^va$</field>
    <description>1Password vault access permissions changed: $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,access_change,</group>
  </rule>

  <!-- Security policy change -->
  <rule id="100714" level="10">
    <if_sid>100710</if_sid>
    <field name="op.action">^update$</field>
    <field name="op.object_type">^p$</field>
    <description>1Password security policy changed by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,policy_change,</group>
  </rule>

  <!-- Service account created or modified -->
  <rule id="100715" level="10">
    <if_sid>100710</if_sid>
    <field name="op.object_type">^sa$</field>
    <description>1Password service account $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,service_account,</group>
  </rule>

  <!-- Account recovery initiated -->
  <rule id="100716" level="12">
    <if_sid>100710</if_sid>
    <field name="op.action">^recover$|^beginrecovery$</field>
    <description>1Password account recovery initiated by $(op.actor_uuid) — security-sensitive action</description>
    <group>onepassword,onepassword_audit,account_recovery,</group>
  </rule>

  <!-- Firewall rule change -->
  <rule id="100717" level="10">
    <if_sid>100710</if_sid>
    <field name="op.object_type">^fw$</field>
    <description>1Password firewall rule $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,firewall_change,</group>
  </rule>

  <!-- Data export or migration -->
  <rule id="100718" level="10">
    <if_sid>100710</if_sid>
    <field name="op.action">^export$</field>
    <description>1Password data export by $(op.actor_uuid) — potential data exfiltration</description>
    <group>onepassword,onepassword_audit,data_export,</group>
  </rule>

  <!-- Billing / subscription change -->
  <rule id="100719" level="5">
    <if_sid>100710</if_sid>
    <field name="op.object_type">^stripe$</field>
    <description>1Password billing change: $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,billing,</group>
  </rule>

  <!-- SSO / integration configuration change -->
  <rule id="100720" level="10">
    <if_sid>100710</if_sid>
    <field name="op.action">^sdvcsso$|^ssotknv$</field>
    <description>1Password SSO configuration changed by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,sso_change,</group>
  </rule>

  <!-- MFA settings changed -->
  <rule id="100721" level="10">
    <if_sid>100710</if_sid>
    <field name="op.action">^enblmfa$|^dsblmfa$</field>
    <description>1Password MFA settings changed by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,mfa_change,</group>
  </rule>

  <!-- Vault created or deleted -->
  <rule id="100722" level="8">
    <if_sid>100710</if_sid>
    <field name="op.object_type">^v$</field>
    <field name="op.action">^create$|^delete$</field>
    <description>1Password vault $(op.action) by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,vault_change,</group>
  </rule>

  <!-- Master password changed -->
  <rule id="100723" level="10">
    <if_sid>100710</if_sid>
    <field name="op.action">^changemp$</field>
    <description>1Password master password changed by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,password_change,</group>
  </rule>

  <!-- Token revoked (service account or integration) -->
  <rule id="100724" level="8">
    <if_sid>100710</if_sid>
    <field name="op.action">^trevoke$</field>
    <description>1Password token revoked by $(op.actor_uuid)</description>
    <group>onepassword,onepassword_audit,token_revocation,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════════════════
       SIGN-IN ATTEMPTS
       ════════════════════════════════════════════════════════════════════════ -->

  <!-- Base sign-in attempt -->
  <rule id="100730" level="3">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^signin_attempt$</field>
    <description>1Password sign-in attempt: $(op.type) [$(op.category)]</description>
    <group>onepassword,onepassword_signin,</group>
  </rule>

  <!-- Successful sign-in -->
  <rule id="100731" level="3">
    <if_sid>100730</if_sid>
    <field name="op.category">^success$</field>
    <description>1Password successful sign-in by $(op.target_user.name) from $(op.country)</description>
    <group>onepassword,onepassword_signin,authentication_success,</group>
  </rule>

  <!-- Failed sign-in -->
  <rule id="100732" level="5">
    <if_sid>100730</if_sid>
    <field name="op.category">^credentials_failed$|^mfa_failed$</field>
    <description>1Password failed sign-in: $(op.category) for $(op.target_user.name) from $(op.country)</description>
    <group>onepassword,onepassword_signin,authentication_failures,</group>
  </rule>

  <!-- Firewall blocked sign-in -->
  <rule id="100733" level="8">
    <if_sid>100730</if_sid>
    <field name="op.category">^firewall_failed$</field>
    <description>1Password sign-in blocked by firewall for $(op.target_user.name) from $(op.country)</description>
    <group>onepassword,onepassword_signin,firewall_block,</group>
  </rule>

  <!-- Modern auth methods -->
  <rule id="100734" level="3">
    <if_sid>100730</if_sid>
    <field name="op.type">^sso$|^passkey$</field>
    <description>1Password $(op.type) sign-in: $(op.category) for $(op.target_user.name)</description>
    <group>onepassword,onepassword_signin,</group>
  </rule>

  <!-- Multiple failed sign-ins for same user (frequency rule) -->
  <rule id="100735" level="12" frequency="3" timeframe="600">
    <if_matched_sid>100732</if_matched_sid>
    <same_field>op.target_user.uuid</same_field>
    <description>1Password multiple failed sign-ins for same user — possible brute force</description>
    <group>onepassword,onepassword_signin,brute_force,</group>
  </rule>

  <!-- Multiple firewall blocks (frequency rule) -->
  <rule id="100736" level="10" frequency="5" timeframe="600">
    <if_matched_sid>100733</if_matched_sid>
    <description>1Password repeated firewall-blocked sign-ins — possible attack</description>
    <group>onepassword,onepassword_signin,firewall_block,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════════════════
       ITEM USAGE EVENTS — vault item access
       ════════════════════════════════════════════════════════════════════════ -->

  <!-- Base item usage event -->
  <rule id="100740" level="3">
    <if_sid>100700</if_sid>
    <field name="op.event_type">^item_usage$</field>
    <description>1Password item usage: $(op.action) by $(op.user.name) in vault $(op.vault_uuid)</description>
    <group>onepassword,onepassword_itemusage,</group>
  </rule>

  <!-- Item revealed or copied (sensitive data access) -->
  <rule id="100741" level="5">
    <if_sid>100740</if_sid>
    <field name="op.action">^reveal$|^secure-copy$</field>
    <description>1Password item revealed/copied by $(op.user.name) — sensitive data accessed</description>
    <group>onepassword,onepassword_itemusage,data_access,</group>
  </rule>

  <!-- Item exported -->
  <rule id="100742" level="8">
    <if_sid>100740</if_sid>
    <field name="op.action">^export$</field>
    <description>1Password item exported by $(op.user.name) — potential data exfiltration</description>
    <group>onepassword,onepassword_itemusage,data_export,</group>
  </rule>

  <!-- Item shared -->
  <rule id="100743" level="8">
    <if_sid>100740</if_sid>
    <field name="op.action">^share$</field>
    <description>1Password item shared by $(op.user.name)</description>
    <group>onepassword,onepassword_itemusage,data_share,</group>
  </rule>

  <!-- Server-side item operations (Connect server, etc.) -->
  <rule id="100744" level="5">
    <if_sid>100740</if_sid>
    <field name="op.action">^server-create$|^server-update$|^server-fetch$</field>
    <description>1Password server-side item operation: $(op.action) by $(op.user.name)</description>
    <group>onepassword,onepassword_itemusage,server_access,</group>
  </rule>

  <!-- SSO provider selected -->
  <rule id="100745" level="3">
    <if_sid>100740</if_sid>
    <field name="op.action">^select-sso-provider$</field>
    <description>1Password SSO provider selected by $(op.user.name)</description>
    <group>onepassword,onepassword_itemusage,sso,</group>
  </rule>

  <!-- Bulk item access (frequency rule — many items in short time) -->
  <rule id="100746" level="10" frequency="10" timeframe="300">
    <if_matched_sid>100740</if_matched_sid>
    <same_field>op.user.uuid</same_field>
    <description>1Password bulk item access by same user — possible credential harvesting</description>
    <group>onepassword,onepassword_itemusage,bulk_access,</group>
  </rule>

  <!-- Bulk export (frequency rule) -->
  <rule id="100747" level="12" frequency="3" timeframe="600">
    <if_matched_sid>100742</if_matched_sid>
    <same_field>op.user.uuid</same_field>
    <description>1Password multiple exports by same user — investigate immediately</description>
    <group>onepassword,onepassword_itemusage,data_export,</group>
  </rule>


  <!-- ════════════════════════════════════════════════════════════════════════
       COMPOSITE / CORRELATION RULES
       ════════════════════════════════════════════════════════════════════════ -->

  <!-- Repeated stream failures across any source -->
  <rule id="100750" level="12" frequency="3" timeframe="600">
    <if_matched_sid>100706</if_matched_sid>
    <description>1Password event streams failing repeatedly — investigate integration health</description>
    <group>onepassword,onepassword_error,correlation,</group>
  </rule>

  <!-- High volume of failed sign-ins across all users -->
  <rule id="100751" level="12" frequency="10" timeframe="600">
    <if_matched_sid>100732</if_matched_sid>
    <description>1Password high volume of failed sign-ins — possible credential stuffing attack</description>
    <group>onepassword,onepassword_signin,correlation,credential_stuffing,</group>
  </rule>

  <!-- Multiple policy or security changes in short time -->
  <rule id="100752" level="12" frequency="3" timeframe="600">
    <if_matched_sid>100714</if_matched_sid>
    <description>1Password multiple security policy changes — possible account takeover</description>
    <group>onepassword,onepassword_audit,correlation,</group>
  </rule>

  <!-- Multiple vault access changes in short time -->
  <rule id="100753" level="10" frequency="5" timeframe="600">
    <if_matched_sid>100713</if_matched_sid>
    <description>1Password multiple vault access changes — review permission modifications</description>
    <group>onepassword,onepassword_audit,correlation,</group>
  </rule>

  <!-- Multiple service account operations in short time -->
  <rule id="100754" level="10" frequency="3" timeframe="600">
    <if_matched_sid>100715</if_matched_sid>
    <description>1Password multiple service account operations — review automation changes</description>
    <group>onepassword,onepassword_audit,correlation,service_account,</group>
  </rule>

</group>
