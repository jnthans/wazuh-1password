# =============================================================================
# .secrets – 1Password Events API credentials
# =============================================================================
#
# This file stores the 1Password Events API bearer token used by the
# Wazuh 1Password wodle to authenticate against the Events API.
#
# HOW TO OBTAIN A BEARER TOKEN
# ─────────────────────────────
# 1. Sign in to your 1Password admin console (https://start.1password.com)
# 2. Navigate to Integrations > Directory > Events Reporting
# 3. Click "Set Up" or "Add Integration"
# 4. Name the integration (e.g., "Wazuh SIEM")
# 5. Select the event types to enable:
#      - Sign-in attempts
#      - Item usage events
#      - Audit events
# 6. Copy the generated bearer token
# 7. Paste it below as the OP_BEARER_TOKEN value
#
# SECURITY
# ────────
# This file should be readable only by root and the wazuh group:
#   chown root:wazuh /var/ossec/wodles/onepassword/.secrets
#   chmod 640 /var/ossec/wodles/onepassword/.secrets
#
# For higher security, consider systemd credentials (LoadCredential)
# which store secrets in memory-backed, encrypted-at-rest storage.
#
# FORMAT
# ──────
# KEY=VALUE pairs, one per line. Lines starting with '#' are comments.
# Values may optionally be quoted (single or double quotes).
# No subshell evaluation is performed.
#
# =============================================================================

OP_BEARER_TOKEN=your-bearer-token-here
